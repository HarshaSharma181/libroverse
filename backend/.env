# ==============================================
# LIBROVERSE - Environment Configuration
# ==============================================

# ----------------------------
# SERVER & APPLICATION
# ----------------------------
PORT=5000
NODE_ENV=development

# ----------------------------
# DATABASE (MongoDB Atlas)
# ----------------------------
MONGO_URI=mongodb+srv://harsha123:sharma@cluster0.qn4s0mi.mongodb.net/libroverse

# ----------------------------
# AUTHENTICATION (JWT)
# ----------------------------
JWT_SECRET=yourSecretKey123
JWT_REFRESH_SECRET=yourRefreshSecretKey456
TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ----------------------------
# EMAIL SERVICE (For Password Reset)
# ----------------------------
# For Gmail users:
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Alternative SMTP configuration (if not using Gmail):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false  # true for 465, false for other ports
# EMAIL_AUTH_USER=your-email@gmail.com
# EMAIL_AUTH_PASS=your-app-password

# ----------------------------
# FRONTEND URLS
# ----------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_RESET_PATH=/reset-password

# ----------------------------
# SECURITY SETTINGS
# ----------------------------
# Password reset rate limiting (attempts per 15 minutes)
PASSWORD_RESET_LIMIT=5
PASSWORD_RESET_WINDOW_MS=900000  # 15 minutes in milliseconds

# Session settings
SESSION_SECRET=yourSessionSecret789
COOKIE_SECURE=false  # Set to true in production with HTTPS

# ----------------------------
# UPLOAD CONFIGURATION
# ----------------------------
MAX_FILE_UPLOAD_SIZE=5000000  # 5MB in bytes
UPLOAD_PATH=./uploads

# ----------------------------
# APPLICATION SETTINGS
# ----------------------------
APP_NAME=LIBROVERSE
APP_VERSION=1.0.0
ADMIN_EMAIL=admin@libroverse.com
SUPPORT_EMAIL=support@libroverse.com

# ----------------------------
# LOGGING
# ----------------------------
LOG_LEVEL=debug  # debug, info, warn, error
LOG_FILE=./logs/app.log

# ----------------------------
# FEATURE FLAGS
# ----------------------------
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PASSWORD_RESET=true
ENABLE_RATE_LIMITING=true
ENABLE_FILE_UPLOADS=true